# ── 安全防护 ──────────────────────────────────────────────

# 禁止目录列表
Options -Indexes

# 保护敏感文件
<FilesMatch "\.(sql|md|log|ini|sh|bak)$">
    Require all denied
</FilesMatch>

# 保护配置文件
<Files "config.php">
    Require all denied
</Files>

# 保护点文件（.git, .htaccess 等）
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# uploads 目录禁止 PHP 执行
<Directory "uploads">
    php_flag engine off
    AddType text/plain .php .php3 .php4 .php5 .phtml .pht
    Options -ExecCGI
</Directory>

# 安全头
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
